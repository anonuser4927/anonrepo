INSERT INTO ROOT ENTITY Workspace (workspace_name) VALUES ('public');

INSERT INTO ENTITY Database (db_name) VALUES ('retail');

WITH temp1 AS (SELECT w.obj_id, w.vid FROM Workspace w WHERE w.workspace_name = 'public'),
temp2 AS (SELECT d.obj_id, d.vid FROM Database d WHERE d.db_name = 'retail') 
INSERT INTO RELATIONSHIP Contains(Workspace, Database) 
SELECT 'Workspace', w.obj_id, w.vid, 'Database', d.obj_id, d.vid FROM temp1 w, temp2 d;


INSERT INTO ENTITY Table (table_name) VALUES ('store_sales1');

WITH temp1 AS (SELECT d.obj_id, d.vid FROM Database d WHERE d.db_name = 'retail'),
temp2 AS (SELECT t.obj_id, t.vid FROM Table t WHERE t.table_name = 'store_sales1') 
INSERT INTO RELATIONSHIP Contains(Database, Table) 
SELECT 'Database', d.obj_id, d.vid, 'Table', t.obj_id, t.vid FROM temp1 d, temp2 t;

INSERT INTO ENTITY TableSnapshot (table_name, create_time, schema, table_type) 
VALUES ('store_sales1', NOW(), NULL,'iceberg');

WITH temp1 AS (SELECT t.obj_id, t.vid FROM Table t WHERE t.table_name = 'store_sales1'),
temp2 AS (SELECT t.obj_id, t.vid FROM TableSnapshot t WHERE t.table_name = 'store_sales1')
INSERT INTO RELATIONSHIP Contains(Table, TableSnapshot) 
SELECT 'Table', t.obj_id, t.vid, 'TableSnapshot', ts.obj_id, ts.vid FROM temp1 t, temp2 ts;

WITH temp1 AS (SELECT t.obj_id, t.vid FROM Table t WHERE t.table_name = 'store_sales1'),
temp2 AS (SELECT t.obj_id, t.vid FROM TableSnapshot t WHERE t.table_name = 'store_sales1')
INSERT INTO RELATIONSHIP Head(Table, TableSnapshot) 
SELECT 'Table', t.obj_id, t.vid, 'TableSnapshot', ts.obj_id, ts.vid FROM temp1 t, temp2 ts;

