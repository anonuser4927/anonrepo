+            Maps.newTreeMap(Comparator.<Integer>reverseOrder()), Lists::newArrayList);
+    groups.put(first.partitionSpecId(), first);
+    remaining.forEachRemaining(manifest -> groups.put(manifest.partitionSpecId(), manifest));
