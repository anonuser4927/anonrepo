+    for (int i = 0; i < bins.size(); i++) {
+      if (mergedFiles[i] != null) {
+        fileLogs.add(new File2(mergedFiles[i].path(), File2.File2Type.ADD, "manifest"));
+        bins.get(i)
+            .forEach(
+                manifest ->
+                    fileLogs.add(new File2(manifest.path(), File2.File2Type.DELETE, "manifest")));
+      }
+    }
