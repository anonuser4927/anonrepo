+        }
+        // prob don't need this, but just in case
+        if (properties.containsKey("raven_address")) {
+            this.conf.set("raven_address", properties.get("raven_address"));
+        }
+        ravenCatalog = new RavenCatalog(conf.get("raven_address"));
+        // A hacky way to pass the workspace name to table ops
+        if (properties.containsKey("workspace_name")) {
+            this.conf.set("workspace_name", properties.get("workspace_name"));
+        }
+
+        this.listAllTables =
+                Boolean.parseBoolean(properties.getOrDefault(LIST_ALL_TABLES, LIST_ALL_TABLES_DEFAULT));
