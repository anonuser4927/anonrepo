+        public final Instant end;
+
+        public TimePair(Instant start, Instant end) {
+            this.start = start;
+            this.end = end;
+        }
+
+        public long getDurationMillis() {
+            return end.toEpochMilli() - start.toEpochMilli();
+        }
+
+        // Getters, equals(), hashCode(), and toString() would go here
+    }
