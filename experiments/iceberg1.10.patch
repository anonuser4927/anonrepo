+    public static class ZipfGenerator {
+        // Notice this is no longer static. It belongs to the instance.
+        private final ThreadLocal<ZipfDistribution> threadLocalZipf;
+
+        public ZipfGenerator(int numTables, double skew) {
+            if (numTables <= 0 || skew <= 0.0) {
+                throw new IllegalArgumentException("numTables and skew must be > 0");
+            }
+
+            // The lambda captures the constructor arguments.
+            // Each thread that calls get() will build its own ZipfDistribution
+            // using these exact config values.
+            this.threadLocalZipf = ThreadLocal.withInitial(
+                    () -> new ZipfDistribution(numTables, skew)
+            );
+        }
+
+        public int getNext() {
+            return threadLocalZipf.get().sample();
+        }
+    }
+
+    public static class RandomOpGenerator {
+        private final float x;
+        private final float xy;    // Precomputed x + y threshold
+        private final float total; // Precomputed total sum (x + y + z)
+
+        public RandomOpGenerator(float x, float y, float z) {
+            if (x < 0 || y < 0 || z < 0 || (x + y + z) == 0.0f) {
+                throw new IllegalArgumentException("Weights must be non-negative and sum to greater than 0");
+            }
+
+            // Precomputing these bounds saves CPU cycles during the next() calls
+            this.x = x;
+            this.xy = x + y;
+            this.total = x + y + z;
+        }
+
+        /**
+         * Generates the next weighted random number (0, 1, or 2).
+         * This method is 100% thread-safe and lock-free.
+         */
+        public int next() {
+            // Generate a random float between 0.0 (inclusive) and total (exclusive)
+            float r = ThreadLocalRandom.current().nextFloat() * total;
+
+            // Find which bucket the random number fell into
+            if (r < x) {
+                return 0; // Hit the 'x' probability slice
+            } else if (r < xy) {
+                return 1; // Hit the 'y' probability slice
+            } else {
+                return 2; // Hit the 'z' probability slice
+            }
+        }
+    }
