+    private static void refreshOp(DuckDBConnection duckDbConn, RavenCatalog ravenCatalog, List<Integer> tableVids,
+                                  Integer threadNum) {
+        try (Statement stmt = duckDbConn.createStatement()) {
+            int numTables = ThreadLocalRandom.current().nextInt(1, MAX_NUM_TABLES_PER_OP + 1);
+
+            // generate tables according to Zipfian distribution
+            List<Integer> tableNumList = Stream.generate(zipfGen::getNext)
+                    .distinct()              // Filters out duplicates
+                    .limit(numTables)        // Stops once we have exactly 'numTables' distinct numbers
+                    .collect(Collectors.toList());
+
+            Instant beforeLoadTables = Instant.now();
+
+            List<String> tableNames = Lists.newArrayList();
+            for (Integer tableNum : tableNumList) {
+                tableNames.add(tableName + String.valueOf(tableNum));
+            }
+
+            // start txn on raven
+            CatalogOuterClass.StartTransactionResponse ravenTxn = ravenCatalog.startTransaction(
+                    workspaceName, dbName, tableNames);
+
+            long txnId = ravenTxn.getTxnId();
+            List<TableObject> unsortedTableObjects = ravenTxn.getTablesList();
+
+            List<TableObject> tableObjects = Lists.newArrayList();
+            for (String name : tableNames) {
+                // brute force way to sort table objects. Should not take too long
+                Optional<TableObject> tableObject = unsortedTableObjects.stream()
+                        .filter(t -> t.getTableName().equals(name)) // The Predicate
+                        .findFirst();
+                tableObjects.add(tableObject.get());
+            }
+
+            List<List<String>> allFilesToScan = Lists.newArrayList();
+            for (int i = 0 ; i < tableNumList.size(); i++) {
+                // retrieve all the file paths from raven which is delta from the current table snapshot.
+                TableObject tableObject = tableObjects.get(i);
+                Integer tableNum = tableNumList.get(i);
+                String query = String.format(Locale.getDefault(),
+                        "SELECT file_path FROM FILELIST DELTA TableSnapshot(%d, %d, %d)",
+                        tableObject.getSnapshotObjId(), tableVids.get(tableNum), tableObject.getSnapshotVid());
+                byte[] resultSet = ravenCatalog.execQuery(query);
+                // extract the data files from the result set buffer
+                List<String> filesToScan = Lists.newArrayList();
+                allFilesToScan.add(filesToScan);
+                RavenCatalog.BufIterator bufIter = new RavenCatalog.BufIterator(resultSet);
+                while (bufIter.valid()) {
+                    bufIter.next();
+                    String path = new String(resultSet, bufIter.dataIdx(), bufIter.elemSize(), UTF_8);
+                    bufIter.next();
+                    filesToScan.add(path);
+                }
+
+                tableVids.set(tableNum, tableObject.getSnapshotVid());
+
+            }
+
+            Instant afterLoadTables = Instant.now();
+
+            for (List<String> filesToScan : allFilesToScan) {
+                if (!filesToScan.isEmpty()) {
+                    String fileToScanStr = filesToScan.stream()
+                            .map(s -> "'" + s + "'")
+                            .collect(Collectors.joining(","));
+                    stmt.execute(
+                            String.format(
+                                    Locale.getDefault(),
+                                    "SELECT * FROM read_parquet([ %s ]);",
+                                    fileToScanStr));
+                }
+            }
+
+            Instant afterInsertFile = Instant.now();
+
+            boolean success = ravenCatalog.commit(txnId);
+
+            Instant afterCommit = Instant.now();
+
+            // record metrics
+            LOAD_TABLE_TIMES.get(threadNum).add(new TimePair(beforeLoadTables, afterLoadTables));
+            INSERT_FILE_TIMES.get(threadNum).add(new TimePair(afterLoadTables, afterInsertFile));
+            COMMIT_TIMES.get(threadNum).add(new TimePair(afterInsertFile, afterCommit));
+            OP_SUCCESS.get(threadNum).add(success);
+            OP_TYPES.get(threadNum).add("refresh");
+
+        } catch (SQLException e) {
+            LOG.info("Database error occurred", e);
+        }
+    }
+
