+    ManifestFile first = manifestIter.next();
+
+    List<ManifestFile> merged = Lists.newArrayList();
+    ListMultimap<Integer, ManifestFile> groups = groupBySpec(first, manifestIter);
+    for (Integer specId : groups.keySet()) {
