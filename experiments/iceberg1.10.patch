+    private static void runVanillaExpImpl() {
+        // Take a given number of measurements
+        for (int i = 0; i < numMeasures; i++) {
+            try (Statement stmt = duckDbConn.createStatement()) {
+                Instant beforeLoadTable = Instant.now();
+
+                // Load table. Load from both hive
+                Table table = catalog.loadTable(TableIdentifier.of(dbName, tableName));
+
+                Instant afterLoadTable = Instant.now();
+
+                // randomly generate lowerBound
+                int lowerBound = ThreadLocalRandom.current().nextInt(1, totalNumRows -
+                        (int) ((float) selectivity * totalNumRows/ 100));
+                int upperBound = lowerBound + (int) ((float) selectivity * totalNumRows/ 100);
+
+                String exprStr = "{\n"
+                        + "  \"type\" : \"and\",\n"
+                        + "  \"left\" : {\n"
+                        + "    \"type\" : \"gt-eq\",\n"
+                        + "    \"term\" : \"ss_sold_date_sk\",\n"
+                        + "    \"value\" : " + String.valueOf(lowerBound) + "\n"
+                        + "  },\n"
+                        + "  \"right\" : {\n"
+                        + "    \"type\" : \"lt\",\n"
+                        + "    \"term\" : \"ss_sold_date_sk\",\n"
+                        + "    \"value\" : " + String.valueOf(upperBound) + "\n"
+                        + "  }\n"
+                        + "}";
+
+                Expression expr = ExpressionParser.fromJson(exprStr);
+                List<String> fileToScan = Lists.newArrayList();
+                try (CloseableIterable<FileScanTask> tasks = table.newScan().filter(expr).planFiles()) {
+                    for (FileScanTask task : tasks) {
+                        fileToScan.add(task.file().location());
+                    }
+                }
+                catch (IOException e) {
+                    LOG.info("IO Exception", e);
+                }
+
+                // turn the list of file paths to a single string
+                String fileToScanStr = fileToScan.stream()
+                        .map(s -> "'" + s + "'")
+                        .collect(Collectors.joining(","));
+
+                Instant afterListFiles = Instant.now();
+
+                // execute selective query against the files
+                // execute selective query against the files
+                stmt.execute(String.format(Locale.getDefault(),
+                        "COPY (SELECT * FROM read_parquet([ %s ]) WHERE ss_sold_date_sk >=" +
+                                " %d AND ss_sold_date_sk < %d) TO '/dev/null' (FORMAT CSV);",
+                        fileToScanStr, lowerBound, upperBound));
+
+                Instant afterSelect = Instant.now();
+
+                LOAD_TABLE_TIMES.add(new ExtendedMORRead.TimePair(beforeLoadTable, afterLoadTable));
+                LIST_FILES_TIMES.add(new ExtendedMORRead.TimePair(afterLoadTable, afterListFiles));
+                SELECT_TIMES.add(new ExtendedMORRead.TimePair(afterListFiles, afterSelect));
+                SELECTED_FILES.add(fileToScan);
+                List<Long> fileSizes = Lists.newArrayList();
+                for (String path : fileToScan) {
+                    fileSizes.add(getFileSize(path));
+                }
+                SELECTED_FILES_SIZE.add(fileSizes);
+
+
+            } catch (SQLException e) {
+                LOG.info("Database error occurred", e);
+            }
+        }
+    }
