+    Tasks.range(bins.size())
+        .stopOnFailure()
+        .throwFailureWhenFinished()
+        .executeWith(workerPoolSupplier.get())
+        .run(
+            index -> {
+              List<ManifestFile> bin = bins.get(index);
+              List<ManifestFile> outputManifests = Lists.newArrayList();
+              binResults[index] = outputManifests;
