+                case INTEGER:
+                    sb.append(String.format(Locale.getDefault(), "x::INTEGER AS %s,", column.name()));
+                    break;
+                case STRING:
+                    sb.append(String.format(Locale.getDefault(), "x::VARCHAR AS %s,", column.name()));
+                    break;
+                default:
+                    break;
+            }
+        }
+        // remove the last comma
+        if (sb.length() > 0) {
+            sb.setLength(sb.length() - 1);
+        }
+
+        return sb.toString();
+    }
