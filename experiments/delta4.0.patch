+
+      Predicate predicate =
+              new And(new Predicate(">=", new Column("ss_sold_date_sk"), Literal.ofInt(lowerBound)),
+                      new Predicate("<", new Column("ss_sold_date_sk"), Literal.ofInt(upperBound)));
