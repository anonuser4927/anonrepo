+      List<PostCommitHook> postCommitHooks = commitResult.getPostCommitHooks();
+      for (PostCommitHook postCommitHook : postCommitHooks) {
+        try {
+          postCommitHook.threadSafeInvoke(engine);
+        } catch (IOException e) {
